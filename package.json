{
  "name": "libavoided-js",
  "version": "0.1.0",
  "description": "Deterministic orthogonal edge router with obstacle avoidance",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./compat": {
      "import": {
        "types": "./dist/compat/index.d.ts",
        "default": "./dist/compat/index.js"
      },
      "require": {
        "types": "./dist/compat/index.d.cts",
        "default": "./dist/compat/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
